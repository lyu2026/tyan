<?xml version='1.0' encoding='utf-8'?>
<widget id="com.tyan" version="2026.5.4"
	xmlns="http://www.w3.org/ns/widgets"
	xmlns:cdv="http://cordova.apache.org/ns/1.0">

	<name>廷琰</name>
	<author>雍爷</author>
	<description>瑞士军刀</description>

	<content src="index.html" />

	<!-- 跨域请求 -->
	<access origin="*" />

	<!-- HTTP/HTTPS 导航 -->
	<allow-navigation href="http://*/*" />
	<allow-navigation href="https://*/*" />

	<!-- 自定义协议 -->
	<allow-intent href="tyan://*" />
	<allow-intent href="http://*/*" />
	<allow-intent href="https://*/*" />

	<!-- HTTP scheme -->
	<preference name="scheme" value="http" />
	<preference name="hostname" value="localhost" />

	<!-- UI -->
	<preference name="Fullscreen" value="true" />
	<preference name="Orientation" value="default" />
	<preference name="loadUrlTimeoutValue" value="30000" />
	<preference name="StatusBarOverlaysWebView" value="false" />
	<preference name="StatusBarBackgroundColor" value="#000000" />

	<!-- 插件 
	<plugin name="cordova-sms-plugin" />
	<plugin name="cordova-plugin-badge" />
	<plugin name="cordova-sqlite-storage" />
	<plugin name="cordova-plugin-device" />
	<plugin name="cordova-plugin-dialogs" />
	<plugin name="cordova-plugin-camera">
		<variable name="ANDROIDX_CORE_VERSION" value="1.6+" />
	</plugin>
	<plugin name="cordova-plugin-contacts" />
	<plugin name="cordova-plugin-geolocation">
		<variable name="GPS_REQUIRED" value="true" />
	</plugin>
	<plugin name="cordova.plugins.diagnostic" />
	<plugin name="cordova-plugin-datepicker" />
	<plugin name="cordova-plugin-native-logs" />
	<plugin name="cordova-plugin-filechooser" />
	<plugin name="cordova-plugin-photo-library" />
	<plugin name="cordova-plugin-nativestorage" />
	<plugin name="cordova-plugin-file" spec="^8.0.0" />
	<plugin name="cordova-plugin-network-information" />
	<plugin name="cordova-plugin-android-fingerprint-auth" />
	<plugin name="cordova-plugin-koofr" spec="https://github.com/lyu2026/cordova-plugin-koofr" />
	-->
	<plugin name="cordova-plugin-advanced-http" spec="*" />
	<plugin name="@e-is/cordova-plugin-downloader" spec="*" />
	<plugin name="cordova-plugin-screen-orientation" spec="*" />
	<plugin name="cordova-plugin-android-permissions" spec="*" />
	<plugin name="cordova-plugin-tyan" spec="https://github.com/lyu2026/cordova-plugin-tyan" />


	<platform name="android">
		<!-- SDK -->
		<preference name="android-minSdkVersion" value="24" />
		<preference name="android-targetSdkVersion" value="34" />

		<!-- 硬件加速 -->
		<preference name="AndroidHardwareAcceleration" value="true" />

		<!-- 允许明文流量 -->
		<preference name="android-usesCleartextTraffic" value="true" />

		<!-- 允许 WebView 不安全文件访问 -->
		<preference name="AndroidInsecureFileModeEnabled" value="true" />

		<!-- 拷贝透明启动屏图片 -->
		<resource-file src="res/splash.png" target="app/src/main/res/drawable/splash.png" />
		<!-- 设置启动屏图标为透明图片 -->
		<preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/splash.png" />
		<!-- 设置启动屏背景色为透明 -->
		<preference name="AndroidWindowSplashScreenBackground" value="@android:color/transparent" />

		<!-- 应用图标 -->
		<icon src="res/icons/ldpi.png" density="ldpi" />
		<icon src="res/icons/mdpi.png" density="mdpi" />
		<icon src="res/icons/hdpi.png" density="hdpi" />
		<icon src="res/icons/xhdpi.png" density="xhdpi" />
		<icon src="res/icons/xxhdpi.png" density="xxhdpi" />
		<icon src="res/icons/xxxhdpi.png" density="xxxhdpi" />
	</platform>
</widget>