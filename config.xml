<?xml version='1.0' encoding='utf-8'?>
<widget id="com.tyan" version="2026.4.14"
	xmlns="http://www.w3.org/ns/widgets"
	xmlns:cdv="http://cordova.apache.org/ns/1.0">

	<name>廷琰</name>
	<author>该隐</author>
	<description>视频资源库</description>

	<content src="index.html"/>

	<!-- 允许所有来源 -->
	<access origin="*"/>
	<!-- 允许所有导航 -->
	<allow-navigation href="*"/>
	<!-- 允许自定义协议 -->
	<allow-intent href="tyan://*"/>
	<!-- 允许所有HTTP请求 -->
	<allow-intent href="http://*/*"/>
	<allow-intent href="https://*/*"/>

	<preference name="scheme" value="http"/>
	<preference name="hostname" value="localhost"/>

	<preference name="Fullscreen" value="true"/>
	<preference name="Orientation" value="default"/>
	<preference name="SplashScreenDelay" value="1"/>
	<preference name="AutoHideSplashScreen" value="true"/>
	<preference name="loadUrlTimeoutValue" value="70000"/>
	<preference name="StatusBarOverlaysWebView" value="false"/>
	<preference name="StatusBarBackgroundColor" value="#000000"/>

	<platform name="android">

		<!-- SDK版本配置 -->
		<preference name="android-minSdkVersion" value="24"/>
		<preference name="android-targetSdkVersion" value="34"/>

		<!-- 硬件加速配置 -->
		<preference name="AndroidHardwareAcceleration" value="true"/>
		<preference name="android-hardwareAccelerated" value="true"/>
		<preference name="AndroidPersistentFileLocation" value="Compatibility"/>

		<!-- 允许HTTP内容在HTTPS中加载 -->
		<preference name="android-usesCleartextTraffic" value="true"/>
		<!-- 禁用默认网络安全配置以支持跨域 -->
		<preference name="android-networkSecurityConfig" value="@xml/network_security_config"/>
		<preference name="AndroidInsecureFileModeEnabled" value="true"/>
		<preference name="AllowUnsecureHTTPS" value="true"/>

		<icon src="icons/ldpi.png" density="ldpi"/>
		<icon src="icons/mdpi.png" density="mdpi"/>
		<icon src="icons/hdpi.png" density="hdpi"/>
		<icon src="icons/xhdpi.png" density="xhdpi"/>
		<icon src="icons/xxhdpi.png" density="xxhdpi"/>
		<icon src="icons/xxxhdpi.png" density="xxxhdpi"/>

	</platform>

	<plugin name="cordova-plugin-file"/>
	<plugin name="cordova-plugin-whitelist"/>
	<plugin name="cordova-plugin-advanced-http"/>
	<plugin name="@e-is/cordova-plugin-downloader"/>
	<plugin name="cordova-plugin-screen-orientation"/>
	<plugin name="cordova-plugin-android-permissions"/>

</widget>
