<?xml version='1.0' encoding='utf-8'?>
<widget id="com.tyan" version="2026.4.27"
	xmlns="http://www.w3.org/ns/widgets"
	xmlns:cdv="http://cordova.apache.org/ns/1.0">

	<name>廷琰</name>
	<author>雍爷</author>
	<description>瑞士军刀</description>

	<content src="index.html"/>

	<!-- 允许所有来源 -->
	<access origin="*"/>
	<!-- 允许所有导航 -->
	<allow-navigation href="*"/>
	<!-- 允许自定义协议 -->
	<allow-intent href="tyan://*"/>
	<!-- 允许所有HTTP请求 -->
	<allow-intent href="http://*/*"/>
	<allow-intent href="https://*/*"/>

	<preference name="scheme" value="http"/>
	<preference name="hostname" value="localhost"/>

	<!-- 禁用启动屏 -->
	<preference name="SplashScreenDelay" value="0"/>
	<preference name="AutoHideSplashScreen" value="true"/>
	<preference name="ShowSplashScreen" value="false"/>
	<preference name="ShowSplashScreenSpinner" value="false"/>
	<preference name="FadeSplashScreen" value="false"/>
	<preference name="FadeSplashScreenDuration" value="0"/>

	<!-- UI设置 -->
	<preference name="Fullscreen" value="true"/>
	<preference name="Orientation" value="default"/>
	<preference name="loadUrlTimeoutValue" value="70000"/>
	<preference name="StatusBarOverlaysWebView" value="false"/>
	<preference name="StatusBarBackgroundColor" value="#000000"/>

	<!-- 插件声明 -->
	<plugin name="cordova-plugin-file" spec="*"/>
	<plugin name="cordova-plugin-device" spec="*"/>
	<plugin name="cordova-plugin-dialogs" spec="*"/>
	<plugin name="cordova-plugin-camera" spec="*">
		<variable name="ANDROIDX_CORE_VERSION" value="1.6+"/>
	</plugin>
	<plugin name="cordova-plugin-whitelist" spec="*"/>
	<plugin name="cordova-plugin-contacts" spec="*"/>
	<plugin name="cordova-plugin-geolocation" spec="*">
		<variable name="GPS_REQUIRED" value="true"/>
	</plugin>
	<plugin name="cordova.plugins.diagnostic" spec="*"/>
	<plugin name="cordova-plugin-advanced-http" spec="*"/>
	<plugin name="@e-is/cordova-plugin-downloader" spec="*"/>
	<plugin name="cordova-plugin-screen-orientation" spec="*"/>
	<plugin name="cordova-plugin-android-permissions" spec="*"/>

	<platform name="android">

		<!-- SDK版本配置 -->
		<preference name="android-minSdkVersion" value="24"/>
		<preference name="android-targetSdkVersion" value="34"/>

		<!-- 网络 -->
		<uses-permission android:name="android.permission.INTERNET"/>
		<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

		<!-- 文件读写 -->
		<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
		<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29"/>
		<!-- Android 13+ 细分媒体权限 -->
		<uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
		<uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
		<uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

		<!-- 拍照 -->
		<uses-permission android:name="android.permission.CAMERA"/>
		<uses-feature android:name="android.hardware.camera" android:required="false"/>
		<uses-feature android:name="android.hardware.camera.autofocus" android:required="false"/>
		<!-- 拍视频需要录音 -->
		<uses-permission android:name="android.permission.RECORD_AUDIO"/>

		<!-- 通讯录 -->
		<uses-permission android:name="android.permission.GET_ACCOUNTS"/>
		<uses-permission android:name="android.permission.READ_CONTACTS"/>
		<uses-permission android:name="android.permission.WRITE_CONTACTS"/>

		<!-- 定位 -->
		<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
		<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
		<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

		<!-- 兼容 Android 10 文件访问 -->
		<edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
			<application android:requestLegacyExternalStorage="true"/>
		</edit-config>

		<!-- 硬件加速配置 -->
		<preference name="AndroidHardwareAcceleration" value="true"/>
		<preference name="android-hardwareAccelerated" value="true"/>
		<preference name="AndroidPersistentFileLocation" value="Compatibility"/>

		<!-- 允许HTTP内容在HTTPS中加载 -->
		<preference name="android-usesCleartextTraffic" value="true"/>
		<!-- 禁用默认网络安全配置以支持跨域 -->
		<preference name="android-networkSecurityConfig" value="@xml/network_security_config"/>
		<preference name="AndroidInsecureFileModeEnabled" value="true"/>
		<preference name="AllowUnsecureHTTPS" value="true"/>

		<icon src="icons/ldpi.png" density="ldpi"/>
		<icon src="icons/mdpi.png" density="mdpi"/>
		<icon src="icons/hdpi.png" density="hdpi"/>
		<icon src="icons/xhdpi.png" density="xhdpi"/>
		<icon src="icons/xxhdpi.png" density="xxhdpi"/>
		<icon src="icons/xxxhdpi.png" density="xxxhdpi"/>

	</platform>

</widget>
